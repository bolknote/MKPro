// Demonstrates optimizer-owned use of the MK61S_MINI expanded RF register.
// Compile with:
//   mkpro-native compile examples/feature-profiles/expanded-rf-preload.mkpro --general-constant-preloads

feature mk61s-mini-expand

program ExpandedRfPreload {
  state {
    score: counter 0..99999 = 0
  }

  loop {
    score = 12345
    halt(score + 12345)
  }
}
