reference bolknote_99_bottles

// Evgeny Stepanishchev's compact MK-61 "99 Bottles" demo displays a calculator
// phrase shaped like "BEEr NN" (on the display: "8,ЕЕГ  NN"). The source says
// that directly: a visible text fragment followed by a two-digit counter.

program NinetyNineBottles {
  state {
    expected_mode_only("grd")

    bottles: counter 0..99 = stack.X
  }

  loop {
    show("BEEr ", bottles:02)
  }
}
