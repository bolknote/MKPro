target mk61
budget 105 cells
optimize size
reference basic_sum

program BasicSum {
  input x: digit
  input y: digit

  state {
    [displayed] result: counter 0..99 = 0
  }

  screen answer {
    show result
    style compact digits
  }

  turn {
    read x
    read y
    result = x + y
    show answer
    stop result
  }
}
