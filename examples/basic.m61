reference basic_sum

// Smallest useful program shape: two inputs become one displayed value. It is
// intentionally boring so parser, allocator, and screen lowering have a stable
// smoke test that is easy to inspect.

program BasicSum {
  state {
    result: counter 0..99 = 0
  }

  turn {
    // The whole observable story is "enter two digits, see their sum"; there is
    // no persistent game state hidden behind the screen.
    read x
    read y
    result = x + y
    stop result
  }
}
