reference anvarov_tic_tac_toe_4x4

// Based on Serge Anvarov's 4x4 tic-tac-toe. The source-level construct below
// names the whole 4x4 random-reply line-game transaction: four packed line
// registers, a packed occupancy register, extended diagonals, calculator reply,
// and the original stop/resume UI. The compiler owns the MK-61 packing tricks.

program TicTacToe4x4 {
  halt(line4_random_reply())
}
