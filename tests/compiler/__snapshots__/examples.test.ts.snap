// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`examples > compiles basic.m61 deterministically > basic.explain 1`] = `
"M61 compile report
Steps: 9/105
Delivery: hex
Optimizer: max
Target profile: mk61_exact
Optimizer rules: automatic=yes; active=3, candidates=25, blocked=0, planned=0
Budget: official=9, extra=0, physical=9
Intent IR: compact=no, highLevel=no; intent=4, effects=9, cells=9

Registers:
  x: R0
  y: R1

Labels:
  main: 00

Optimizations:
  - stack-current-x-scheduling: Reused y already in X for commutative +.
  - store-recall-peephole: Dropped 2 redundant П->X immediately after X->П to the same register.
  - dead-temp-store: Removed 1 temp store(s) whose X value was consumed directly by stack scheduling.

Proofs:
  - return-stack-empty: proved; No ПП opcodes were emitted; empty return stack precondition holds for В/О-as-БП01 rewrites."
`;

